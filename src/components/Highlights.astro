<section id="highlights" class="py-20 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-timber text-xs font-medium tracking-widest uppercase mb-3">Why N58</p>
      <h2 class="font-display text-4xl text-zinc-900">Made for the outdoors.</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {highlights.map(h => (
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="text-3xl mb-4">{h.icon}</div>
          <h3 class="font-semibold text-zinc-900 mb-2">{h.title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{h.desc}</p>
        </div>
      ))}
    </div>
  </div>
