---
// Add photos to public/images/ and list them here.
// featured: true makes the image span 2 columns and 2 rows as the hero grid item.
const photos = [
  { src: '/images/gallery-terrace-deck.jpg', alt: 'Wood deck terrace with bioclimatic pergola and seating — N58 Carnikava', featured: true },
  { src: '/images/gallery-living-terrace.jpg', alt: 'Open-plan living and dining area with view to terrace — N58 Carnikava' },
  { src: '/images/gallery-living-overview.jpg', alt: 'Living room with smart TV, dining table and kitchen — N58 Carnikava' },
  { src: '/images/gallery-kitchen.jpg', alt: 'Fully equipped kitchen with white cabinets and oak worktop — N58 Carnikava' },
  { src: '/images/gallery-bedroom-1.jpg', alt: 'Master bedroom with double bed and air conditioning — N58 Carnikava' },
  { src: '/images/gallery-bedroom-2.jpg', alt: 'Second bedroom with single bed — N58 Carnikava' },
  { src: '/images/gallery-bathroom.jpg', alt: 'Bathroom with walk-in shower — N58 Carnikava' },
  { src: '/images/gallery-terrace-bbq.jpg', alt: 'Covered terrace with BBQ grill and outdoor dining — N58 Carnikava' },
  { src: '/images/gallery-river.jpg', alt: 'Vecgauja river with boats and pine forest — Carnikava Latvia' },
  { src: '/images/gallery-exterior.jpg', alt: 'N58 exterior with large private garden — Carnikava Latvia' },
  { src: '/images/gallery-entrance.jpg', alt: 'Entrance hallway with oak wardrobe — N58 Carnikava' },
];
---

<section id="gallery" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="text-timber text-xs font-medium tracking-widest uppercase mb-3">The Property</p>
      <h2 class="font-display text-4xl text-zinc-900">See every corner.</h2>
    </div>

    <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {photos.map((photo, i) => (
        <div
          class:list={[
            'relative overflow-hidden rounded-xl bg-zinc-100 cursor-pointer group',
            photo.featured ? 'col-span-2 row-span-2 aspect-[4/3]' : 'aspect-square',
            !photo.src && 'cursor-default',
          ]}
          data-photo-src={photo.src ?? ''}
          data-photo-alt={photo.alt}
          data-photo-index={i}
        >
          {photo.src ? (
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ) : (
            <div class="w-full h-full flex flex-col items-center justify-center text-zinc-300 select-none">
              <svg class="w-8 h-8 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="text-xs">Coming soon</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<dialog
  id="lightbox"
  class="fixed inset-0 w-screen h-screen max-w-none m-0 p-0 bg-transparent border-0"
>
  <div class="w-full h-full bg-black/90 flex items-center justify-center p-4">
    <button
      id="lightbox-close"
      class="absolute top-5 right-6 text-white/60 hover:text-white text-4xl leading-none"
      aria-label="Close"
    >&times;</button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg" />
  </div>
</dialog>

<script>
  const grid = document.getElementById('gallery-grid');
  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const closeBtn = document.getElementById('lightbox-close');

  grid?.addEventListener('click', (e) => {
    const item = (e.target as Element).closest('[data-photo-src]') as HTMLElement | null;
    if (!item) return;
    const src = item.dataset.photoSrc;
    if (!src || !img || !dialog) return;
    img.src = src;
    img.alt = item.dataset.photoAlt ?? '';
    dialog.showModal();
  });

  closeBtn?.addEventListener('click', () => dialog?.close());

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
